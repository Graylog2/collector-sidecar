<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- UpgradeCode: MINT ONCE, NEVER CHANGE. -->
  <?define UpgradeCode = "C57C74A4-E5B1-4014-A0FC-17E9A4DB5A2B" ?>

  <Package
      Name="Graylog Collector"
      Manufacturer="Graylog, Inc."
      Version="$(Version)"
      UpgradeCode="$(var.UpgradeCode)"
      Scope="perMachine"
      Language="1033"
      Compressed="yes">

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of Graylog Collector is already installed."
        Schedule="afterInstallExecute" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="graylog.ico" SourceFile="graylog.ico" />
    <Property Id="ARPPRODUCTICON" Value="graylog.ico" />
    <Property Id="ARPHELPLINK" Value="https://docs.graylog.org/" />
    <Property Id="ARPURLINFOABOUT" Value="https://www.graylog.org/" />
    <Property Id="SERVERURL" Secure="yes">
      <RegistrySearch Id="ExistingServerUrl"
                      Root="HKLM"
                      Key="SOFTWARE\Graylog\Collector"
                      Name="SERVERURL"
                      Type="raw" />
    </Property>

    <Property Id="TOKEN" Secure="yes">
      <RegistrySearch Id="ExistingToken"
                      Root="HKLM"
                      Key="SOFTWARE\Graylog\Collector"
                      Name="TOKEN"
                      Type="raw" />
    </Property>

    <Property Id="REMOVE_DATA" Secure="yes" Value="0" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="GraylogDir" Name="Graylog">
        <Directory Id="INSTALLFOLDER" Name="Collector">
          <Component Id="CollectorExe" Guid="*">
            <File Id="graylog_collector_exe"
                  Source="$(var.SourceExe)"
                  KeyPath="yes" />

            <ServiceInstall
                Id="GraylogCollectorService"
                Name="graylog-collector"
                DisplayName="Graylog Collector"
                Description="Managed Graylog log collector."
                Type="ownProcess"
                Start="auto"
                ErrorControl="normal"
                Account="LocalSystem"
                Arguments="supervisor"
                Vital="yes" />

            <ServiceControl
                Id="GraylogCollectorServiceControl"
                Name="graylog-collector"
                Start="install"
                Stop="both"
                Remove="uninstall"
                Wait="no" />
          </Component>
          <Component Id="CollectorLicense" Guid="*">
            <File Id="LICENSE_txt"
                  Source="$(var.LicenseFile)"
                  Name="LICENSE"
                  KeyPath="yes" />
          </Component>

          <Component Id="InstallStateMirror" Guid="*">
            <RegistryKey Root="HKLM" Key="SOFTWARE\Graylog\Collector">
              <RegistryValue Name="SERVERURL" Type="string" Value="[SERVERURL]" KeyPath="yes" />
              <RegistryValue Name="TOKEN"     Type="string" Value="[TOKEN]" />
            </RegistryKey>
          </Component>

          <Component Id="ServiceEnvironment" Guid="*">
            <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\graylog-collector">
              <RegistryValue Name="Environment" Type="multiString" KeyPath="yes">
                <MultiStringValue Value="GLC_SERVER__AUTH__ENROLLMENT_ENDPOINT=[SERVERURL]" />
                <MultiStringValue Value="GLC_SERVER__AUTH__ENROLLMENT_TOKEN=[TOKEN]" />
              </RegistryValue>
            </RegistryKey>
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="CommonAppGraylogDir" Name="Graylog">
        <Directory Id="PROGRAMDATAFOLDER" Name="Collector">
          <Component Id="ProgramDataDir" Guid="9BB8A27D-C01D-42A9-B5C0-4C1E1E31714C">
            <CreateFolder />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <UIRef Id="GraylogUI" />

    <Feature Id="Main" Title="Graylog Collector" Level="1">
      <ComponentRef Id="CollectorExe" />
      <ComponentRef Id="CollectorLicense" />
      <ComponentRef Id="InstallStateMirror" />
      <ComponentRef Id="ServiceEnvironment" />
      <ComponentRef Id="ProgramDataDir" />
    </Feature>

    <!-- Immediate: build the command line in CustomActionData for the deferred action. -->
    <CustomAction Id="PurgeProgramDataSetData"
                  Property="PurgeProgramData"
                  Value='&quot;[%ComSpec]&quot; /c rmdir /s /q &quot;[PROGRAMDATAFOLDER]&quot;' />

    <!-- Deferred: runs elevated and executes the command line from CustomActionData. -->
    <CustomAction Id="PurgeProgramData"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixQuietExec"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="PurgeProgramDataSetData"
              Before="PurgeProgramData"
              Condition='REMOVE_DATA="1" AND REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE' />
      <Custom Action="PurgeProgramData"
              After="RemoveFiles"
              Condition='REMOVE_DATA="1" AND REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE' />
    </InstallExecuteSequence>

  </Package>
</Wix>
