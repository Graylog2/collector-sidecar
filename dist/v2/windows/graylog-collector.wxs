<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- UpgradeCode: MINT ONCE, NEVER CHANGE. -->
  <?define UpgradeCode = "C57C74A4-E5B1-4014-A0FC-17E9A4DB5A2B" ?>

  <Package
      Name="Graylog Collector"
      Manufacturer="Graylog, Inc."
      Version="$(Version)"
      UpgradeCode="$(var.UpgradeCode)"
      Scope="perMachine"
      Language="1033"
      Compressed="yes">

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of Graylog Collector is already installed."
        Schedule="afterInstallExecute" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="graylog.ico" SourceFile="graylog.ico" />
    <Property Id="ARPPRODUCTICON" Value="graylog.ico" />
    <Property Id="ARPHELPLINK" Value="https://docs.graylog.org/" />
    <Property Id="ARPURLINFOABOUT" Value="https://www.graylog.org/" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <Property Id="SERVERURL" Secure="yes" />
    <Property Id="TOKEN" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="GraylogDir" Name="Graylog">
        <Directory Id="INSTALLFOLDER" Name="Collector">
          <Component Id="CollectorExe" Guid="*">
            <File Id="graylog_collector_exe"
                  Source="$(var.SourceExe)"
                  KeyPath="yes" />

            <ServiceInstall
                Id="GraylogCollectorService"
                Name="graylog-collector"
                DisplayName="Graylog Collector"
                Description="OpenTelemetry-based log collector, managed by Graylog."
                Type="ownProcess"
                Start="auto"
                ErrorControl="normal"
                Account="LocalSystem"
                Arguments="supervisor"
                Vital="yes" />

            <ServiceControl
                Id="GraylogCollectorServiceControl"
                Name="graylog-collector"
                Start="install"
                Stop="both"
                Remove="uninstall"
                Wait="yes" />
          </Component>
          <Component Id="CollectorLicense" Guid="*">
            <File Id="LICENSE_txt"
                  Source="$(var.LicenseFile)"
                  Name="LICENSE"
                  KeyPath="yes" />
          </Component>

          <Component Id="InstallStateMirror" Guid="*">
            <RegistryKey Root="HKLM" Key="SOFTWARE\Graylog\Collector">
              <RegistryValue Name="SERVERURL" Type="string" Value="[SERVERURL]" KeyPath="yes" />
              <RegistryValue Name="TOKEN"     Type="string" Value="[TOKEN]" />
            </RegistryKey>
          </Component>

          <Component Id="ServiceEnvironment" Guid="*">
            <RegistryKey Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\graylog-collector">
              <RegistryValue Name="Environment" Type="multiString" KeyPath="yes">
                <MultiStringValue>GLC_SERVER__AUTH__ENROLLMENT_ENDPOINT=[SERVERURL]</MultiStringValue>
                <MultiStringValue>GLC_SERVER__AUTH__ENROLLMENT_TOKEN=[TOKEN]</MultiStringValue>
              </RegistryValue>
            </RegistryKey>
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="CommonAppGraylogDir" Name="Graylog">
        <Directory Id="PROGRAMDATAFOLDER" Name="Collector" />
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Graylog Collector" Level="1">
      <ComponentRef Id="CollectorExe" />
      <ComponentRef Id="CollectorLicense" />
      <ComponentRef Id="InstallStateMirror" />
      <ComponentRef Id="ServiceEnvironment" />
    </Feature>

  </Package>
</Wix>
